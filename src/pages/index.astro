---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="作品集 | 独立游戏" description="独立游戏开发者作品集：关于我、作品、素材与联系方式。">
	<div class="page-root">
		<header class="site-nav" aria-label="站点">
			<div class="nav-left">
				<a class="brand" href="#top">阿罗</a>
				<button type="button" id="btn-back" class="btn-back">返回首页</button>
			</div>
			<nav class="nav-main" aria-label="主导航">
				<a href="#about">关于我</a>
				<a href="#games">游戏原型</a>
				<a href="#ai-explore">AI系统展示</a>
				<a href="#assets">素材</a>
				<a href="#contact">联系</a>
			</nav>
			<span class="nav-balance" aria-hidden="true"></span>
		</header>

		<!-- 首屏：整幅 bg 自下升起（替代原左右双横幅），向下滚动进入正文 -->
		<section id="top" class="cover-screen cover-screen--intro" aria-label="首页首屏">
			<div class="cover-bg-rise" aria-hidden="true"></div>
			<div class="cover-inner">
				<h1 class="cover-landing-title">
					<span class="cover-landing-title__main">作品集</span>
					<span class="cover-landing-title__sub">独立游戏 · 阿罗</span>
				</h1>
			</div>
		</section>

		<div id="showcase-screen" class="showcase-screen">
			<main id="home">
			<section id="about" class="section section-about">
				<div class="container">
					<h2>关于我</h2>
					<p>
						你好，我是阿罗，我关注交互系统、AI 与游戏技术中的原型探索，喜欢研究技术如何形成行为、体验与新的交互方式。。
					</p>
					<p>
						您可以试玩我的游戏 demo、通过小交互体验我开发的 Agent 开发系统、观智能 NPC 系统演示（还在制作）
					</p>
				</div>
			</section>

			<section id="games" class="section">
				<div class="container">
					<h2>游戏原型</h2>
					<div class="grid">
						<article class="card card-with-preview">
							<a
								class="card-preview"
								href="https://princess-wen.itch.io/the-story-of-the-farm"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="The Story of the Farm：在 itch.io 打开"
							>
								<!-- itch 项目封面图；建议后续替换为本地静态图避免外链变更 -->
								<img
									src={`${base}previews/the-story-of-the-farm-cover.png`}
									alt="The Story of the Farm 封面预览"
									width="800"
									height="450"
									loading="lazy"
									decoding="async"
								/>
							</a>
							<div class="card-body">
								<h3>
									The Story of the Farm
								</h3>
								<p>游戏原型 <a
										href="https://princess-wen.itch.io/the-story-of-the-farm"
										target="_blank"
										rel="noopener noreferrer"
										>在 itch.io 试玩</a
									></p>
								<p>引擎：Unity</p>
								<p>
									轻量级农场题材游戏框架原型，包含全局管理、事件中心、ScriptableObject 配置驱动、资源与 UI 管理及本地持久化等核心模块。
								</p>
							</div>
						</article>
						<article class="card card-with-preview">
							<a
								class="card-preview"
								href="https://www.bilibili.com/video/BV1AZ5J6TE9x/"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="智能 NPC 对话演示：在哔哩哔哩打开"
							>
								<img
									src={`${base}cover.png`}
									alt="像素风农场场景中 Mayor NPC 与玩家对话界面预览"
									width="800"
									height="450"
									loading="lazy"
									decoding="async"
								/>
							</a>
							<div class="card-body">
								<h3>智能 NPC 对话演示</h3>
								<p>
									演示视频
									<a
										href="https://www.bilibili.com/video/BV1AZ5J6TE9x/"
										target="_blank"
										rel="noopener noreferrer"
										>在哔哩哔哩观看</a
									>
								</p>
								<p>引擎：Unity</p>
								<p>
									基于前一个2DRPG游戏的扩建，LLM大模型对话/NPC记忆管理/LLM游戏内行为触发三个方向的探索
								</p>
							</div>
						</article>
					</div>
				</div>
			</section>

			<section id="ai-explore" class="section">
				<div class="container">
					<h2>AI系统展示</h2>
					<div class="grid">
						<article class="card">
							<h3>合同风险审核系统（已完成）</h3>
							<p><strong>输入：</strong>合同文本</p>
							<p><strong>输出：</strong>风险点 + 解释</p>
							<p><strong>技术栈：</strong>Agent流程 / 检索增强 / 风险判断 / 解释生成</p>
							<p><strong>流程图：</strong></p>
							<div class="flow-diagram" aria-label="合同风险审核流程">
								<span>合同文本</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>条款检索</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>风险判断</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>解释生成</span>
							</div>
						</article>
						<article class="card">
							<h3>合同风险审核演示</h3>
							<div class="contract-demo">
								<div class="contract-source" aria-label="合同原文示例">
									<p>
										<strong>合同原文：</strong>
										A句：乙方交付延期时，甲方有权单方面解除合同且无需承担任何补偿责任。
									</p>
									<p>
										B句：双方因履行本合同产生争议时，应先友好协商，协商不成可提交甲方所在地法院处理。
									</p>
								</div>
								<div class="contract-actions">
									<button type="button" id="btn-contract-review" class="btn-demo">
										发送审核
									</button>
									<button type="button" id="btn-contract-reset" class="btn-demo btn-demo-secondary" hidden>
										重新生成
									</button>
								</div>
							</div>
						</article>
						<article id="contract-result" class="card contract-result-card" hidden>
							<h3>审核结果展示</h3>
							<div class="contract-result">
								<div class="risk-item">
									<p>
										<span class="contract-highlight risk-high">A句高亮</span>
										<span class="risk-label risk-high">风险 高</span>
									</p>
									<p>原因：后面补。</p>
									<p>建议：后面补。</p>
								</div>
								<div class="risk-item">
									<p>
										<span class="contract-highlight risk-medium">B句高亮</span>
										<span class="risk-label risk-medium">风险 中</span>
									</p>
									<p>原因：后面补。</p>
									<p>建议：后面补。</p>
								</div>
							</div>
						</article>
						<article class="card card-wide">
							<h3>基于语义理解的 NPC 智能记忆与行为触发系统（在研）</h3>
							<p><strong>行为模型：</strong>目标驱动 / 记忆系统</p>
							<div class="flow-diagram" aria-label="NPC 行为流程">
								<span>玩家输入</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>意图识别</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>状态更新</span>
								<span class="flow-arrow" aria-hidden="true">→</span>
								<span>行为输出</span>
							</div>
						</article>
					</div>
				</div>
			</section>

			<section id="assets" class="section">
				<div class="container">
					<h2>素材</h2>
					<div class="grid">
						<article class="card">
							<h3>UI 资源包</h3>
							<p>按钮、面板与 HUD，适合奇幻题材项目。</p>
						</article>
						<article class="card">
							<h3>场景资源包</h3>
							<p>低多边形道具、模块化地形与植被等。</p>
						</article>
					</div>
				</div>
			</section>

			<section id="contact" class="section">
				<div class="container">
					<h2>联系</h2>
					<p>邮箱：<a href="mailto:@example.com">shuyuluo1119@gmail.com</a></p>
					<p>GitHub：<a href="https://github.com/yourname">https://github.com/</a></p>
					<p>Itch.io：<a href="https://yourname.itch.io">yourname.itch.io</a></p>
				</div>
			</section>
		</main>
	</div>

	<script is:inline>
		// 避免刷新后仍落在「关于我」等区块：关闭浏览器自动恢复滚动；按进入方式决定是否保留锚点。
		(function syncInitialScroll() {
			if ('scrollRestoration' in history) {
				history.scrollRestoration = 'manual';
			}

			function apply() {
				const nav = performance.getEntriesByType?.('navigation')?.[0];
				if (nav?.type === 'reload') {
					if (location.hash) {
						history.replaceState(null, '', location.pathname + location.search);
					}
					window.scrollTo(0, 0);
					return;
				}

				const hash = location.hash;
				if (!hash || hash === '#' || hash === '#top') {
					window.scrollTo(0, 0);
					return;
				}

				const id = decodeURIComponent(hash.slice(1)).split(':')[0];
				const el = document.getElementById(id);
				if (el) {
					requestAnimationFrame(() => {
						el.scrollIntoView({ behavior: 'auto', block: 'start' });
					});
				} else {
					window.scrollTo(0, 0);
				}
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', apply, { once: true });
			} else {
				apply();
			}
		})();

		function scrollToTopHero() {
			const top = document.getElementById('top');
			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			top?.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
		}

		document.getElementById('btn-back')?.addEventListener('click', scrollToTopHero);

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			document.getElementById('top')?.classList.add('cover-screen--reduced-motion');
		}

		const contractReviewButton = document.getElementById('btn-contract-review');
		const contractResetButton = document.getElementById('btn-contract-reset');
		const contractResult = document.getElementById('contract-result');
		contractReviewButton?.addEventListener('click', () => {
			contractResult?.removeAttribute('hidden');
			contractResetButton?.removeAttribute('hidden');
			contractReviewButton.textContent = '已生成审核结果';
		});
		contractResetButton?.addEventListener('click', () => {
			contractResult?.setAttribute('hidden', '');
			contractResetButton.setAttribute('hidden', '');
			if (contractReviewButton) {
				contractReviewButton.textContent = '发送审核';
			}
		});
	</script>
	</div>
</Layout>

<style define:vars={{ bgImage: `url('${base}bg.jpg')` }}>
	/* 首屏：文档流满屏高度，下滚进入正文；导航固定在上层 */
	.cover-screen {
		position: relative;
		z-index: 0;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		justify-content: stretch;
		min-height: 100vh;
		min-height: 100dvh;
		background-color: #fff;
		overflow: hidden;
	}

	/* 整幅插画层：初始在视口下方，自下升入首屏（接替原双横幅动效） */
	.cover-bg-rise {
		position: absolute;
		inset: 0;
		z-index: 0;
		background-color: #fff;
		background-image: var(--bgImage);
		background-repeat: no-repeat;
		background-position: center 75%;
		background-size: min(120vw, 1400px) auto;
		transform: translateY(100%);
		will-change: transform;
		pointer-events: none;
	}

	.cover-landing-title {
		position: absolute;
		top: clamp(8vh, 13vw, 16vh);
		left: 50%;
		z-index: 1;
		width: min(92vw, 880px);
		margin: 0;
		padding: 0 0.5rem;
		pointer-events: none;
		text-align: center;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: #141a28;
		text-shadow: 0 1px 0 rgba(255, 255, 255, 0.9);
		opacity: 0;
		/* 入场自上方下沉，位移下降 */
		transform: translateX(-50%) translateY(-220px);
		will-change: opacity, transform;
	}

	.cover-landing-title__main {
		display: block;
		font-size: clamp(2.35rem, 7.5vw, 4.1rem);
		line-height: 1.06;
	}

	.cover-landing-title__sub {
		display: block;
		margin-top: 0.42em;
		font-size: clamp(0.88rem, 2.4vw, 1.18rem);
		font-weight: 500;
		letter-spacing: 0.16em;
		color: rgba(36, 52, 88, 0.88);
	}

	.cover-screen--intro:not(.cover-screen--reduced-motion) .cover-landing-title {
		animation: cover-landing-title-in 1.35s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
	}

	.cover-screen--intro:not(.cover-screen--reduced-motion) .cover-bg-rise {
		animation: cover-bg-rise 1.12s cubic-bezier(0.22, 1, 0.36, 1) 0.72s forwards;
	}

	.cover-screen--reduced-motion .cover-landing-title {
		animation: none !important;
		opacity: 1 !important;
		transform: translateX(-50%) translateY(0) !important;
	}

	.cover-screen--reduced-motion .cover-bg-rise {
		animation: none !important;
		transform: translateY(0) !important;
	}

	@keyframes cover-landing-title-in {
		from {
			opacity: 0;
			transform: translateX(-50%) translateY(-220px);
		}
		to {
			opacity: 1;
			transform: translateX(-50%) translateY(0);
		}
	}

	@keyframes cover-bg-rise {
		from {
			transform: translateY(100%);
		}
		to {
			transform: translateY(0);
		}
	}

	.cover-screen--intro:not(.cover-screen--reduced-motion) {
		animation: cover-screen-in 1.1s ease forwards;
	}

	@keyframes cover-screen-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.cover-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex: 1;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 0;
		padding: 1rem;
	}

	.showcase-screen {
		display: block;
	}

	.container {
		width: min(1000px, calc(100% - 2rem));
		margin: 0 auto;
	}

	.nav-left {
		justify-self: start;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem 1rem;
		pointer-events: auto;
	}

	.btn-back {
		padding: 0.35rem 0.85rem;
		font: inherit;
		font-size: 0.85rem;
		letter-spacing: 0.06em;
		color: #243458;
		background: rgba(255, 255, 255, 0.85);
		border: 1px solid rgba(36, 52, 88, 0.25);
		border-radius: 8px;
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease;
	}

	.btn-back:hover,
	.btn-back:focus-visible {
		color: #141a28;
		border-color: rgba(36, 52, 88, 0.45);
		background: #fff;
		outline: none;
	}

	.site-nav {
		position: fixed;
		inset: 0 0 auto 0;
		z-index: 40;
		display: grid;
		grid-template-columns: 1fr auto;
		align-items: start;
		column-gap: 0.75rem;
		padding: 1.15rem clamp(1rem, 4vw, 2rem);
		pointer-events: none;
	}

	.brand {
		font-size: 0.95rem;
		font-weight: 600;
		color: #1a2744;
		text-decoration: none;
		letter-spacing: 0.03em;
	}

	.brand:hover,
	.brand:focus-visible {
		color: #0d1528;
	}

	.nav-main {
		justify-self: end;
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		align-items: center;
		gap: 0.45rem 1.35rem;
		pointer-events: auto;
	}

	.nav-main a {
		color: rgba(26, 39, 68, 0.9);
		text-decoration: none;
		font-size: calc(0.95rem + 3.5px);
		letter-spacing: 0.02em;
	}

	.nav-main a:hover,
	.nav-main a:focus-visible {
		color: #0d1528;
	}

	.nav-balance {
		justify-self: end;
		width: 0;
		height: 0;
		overflow: hidden;
		pointer-events: none;
	}

	@media (max-width: 640px) {
		.site-nav {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.85rem;
		}

		.nav-left {
			align-self: stretch;
			justify-content: space-between;
		}

		.nav-balance {
			display: none;
		}

		.cover-bg-rise {
			background-position: center 82%;
			background-size: min(160vw, 900px) auto;
		}
	}

	#about.section-about {
		padding-top: clamp(5rem, 12vw, 6.25rem);
		border-top: none;
		text-align: center;
	}

	#about.section-about .container {
		text-align: center;
	}

	#about.section-about h2 {
		font-size: calc(2.6rem);
		color: #000;
	}

	#games h2 {
		font-size: calc(2.6rem);
		color: #000;
		text-align: center;
	}

	#ai-explore h2 {
		font-size: 2.6rem;
		color: #000;
		text-align: center;
	}

	#about.section-about p {
		font-size: calc(1rem + 0.5rem + 2px - 3px);
		max-width: 60ch;
		margin-left: auto;
		margin-right: auto;
		text-align: left;
		color: #000;
	}

	#about.section-about strong {
		color: #000;
		font-weight: 700;
	}

	#about.section-about .text-accent-orange {
		color: #ffc78f;
	}

	.section {
		padding: 3rem 0;
		border-top: 1px solid rgba(15, 23, 42, 0.1);
		scroll-margin-top: 5.5rem;
	}

	h2 {
		margin: 0 0 1rem;
		font-size: 1.6rem;
		color: #1a2744;
	}

	p {
		font-size: calc(1rem + 2px);
		line-height: 1.7;
		color: #3d4a66;
	}

	#contact p:first-of-type {
		font-size: calc(1rem + 3px);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.card {
		padding: 1rem;
		background: #131b32;
		border: 1px solid rgba(141, 177, 255, 0.2);
		border-radius: 12px;
	}

	.card-with-preview {
		padding: 0;
		overflow: hidden;
	}

	.card-with-preview .card-body {
		padding: 1rem;
	}

	.card-preview {
		display: block;
		line-height: 0;
		background: #0a0f1a;
	}

	.card-preview:focus-visible {
		box-shadow: inset 0 0 0 2px #8db1ff;
	}

	.card-preview img {
		width: 100%;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
		transition: opacity 0.2s ease;
	}

	.card-preview:hover img,
	.card-preview:focus-visible img {
		opacity: 0.92;
	}

	/* 游戏原型：白底卡片（仅 #games；#assets 等仍为深色卡） */
	#games .card {
		background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
		border: 1px solid rgba(15, 23, 42, 0.08);
		border-radius: 16px;
		box-shadow:
			0 1px 2px rgba(15, 23, 42, 0.04),
			0 8px 24px rgba(15, 23, 42, 0.06);
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease,
			border-color 0.2s ease;
	}

	#games .card:hover {
		border-color: rgba(15, 23, 42, 0.12);
		box-shadow:
			0 2px 4px rgba(15, 23, 42, 0.06),
			0 12px 32px rgba(15, 23, 42, 0.1);
		transform: translateY(-2px);
	}

	#games .card-with-preview {
		padding: 0;
		overflow: hidden;
	}

	#games .card-with-preview .card-body {
		padding: 1.15rem 1.25rem;
	}

	#games .card-preview {
		background: #f1f5f9;
