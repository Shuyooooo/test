---
interface Props {
	title?: string;
	description?: string;
}

const { title = 'Game Portfolio', description = 'Personal game portfolio website' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style
	is:global
	define:vars={{
		fontSrc: `url('${base}default_ttf_1.ttf') format('truetype')`,
	}}
>
	/* 展示字体：只维护 public/default_ttf_1.ttf，换字体时覆盖该文件即可。旧文件 今年也要加油鸭.ttf / jia-you-ya.ttf 若存在可手动删除。 */
	@font-face {
		font-family: 'DefaultTTF1';
		src: var(--fontSrc);
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	:root {
		font-family:
			'DefaultTTF1',
			'PingFang SC',
			'Microsoft YaHei',
			'Segoe UI',
			sans-serif;
		color-scheme: light;
	}

	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html {
		scroll-padding-top: 5.5rem;
	}

	html,
	body {
		margin: 0;
		min-height: 100%;
		background-color: #fff;
		color: #1a1d24;
	}

	body {
		overflow: auto;
	}
</style>
